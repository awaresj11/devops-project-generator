# Security Audit ConfigMap
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ project_name }}-audit-config
  namespace: {{ project_name }}
  labels:
    app: {{ project_name }}
    security-framework: nist-csf
data:
  audit-policy.yaml: |
    # Audit policy for NIST CSF compliance
    apiVersion: audit.k8s.io/v1
    kind: Policy
    rules:
    # Log all changes to sensitive resources
    - level: Metadata
      namespaces: [{{ project_name }}]
      resources:
      - group: ""
        resources: ["secrets", "configmaps"]
      - group: "rbac.authorization.k8s.io"
        resources: ["roles", "rolebindings", "clusterroles", "clusterrolebindings"]
    # Log all authentication failures
    - level: Metadata
      namespaces: [{{ project_name }}]
      nonResourceURLs: ["/api/*", "/healthz"]
      verbs: ["create", "update", "patch", "delete"]
    # Log all pod and service operations
    - level: Request
      namespaces: [{{ project_name }}]
      resources:
      - group: ""
        resources: ["pods", "services"]
      - group: "apps"
        resources: ["deployments", "replicasets"]
---
# Compliance Check CronJob
apiVersion: batch/v1
kind: CronJob
metadata:
  name: {{ project_name }}-compliance-check
  namespace: {{ project_name }}
  annotations:
    nist-csf.control: "DE.CM-1"
    description: "Continuous monitoring for NIST CSF compliance"
spec:
  schedule: "0 2 * * *"  # Daily at 2 AM
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: compliance-checker
            image: aquasec/trivy:latest
            command:
            - /bin/sh
            - -c
            - |
              echo "Running NIST CSF compliance check..."
              trivy image --severity HIGH,CRITICAL {{ project_name }}:latest
              echo "Compliance check completed"
          restartPolicy: OnFailure

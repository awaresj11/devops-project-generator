# Resource Quotas
apiVersion: v1
kind: ResourceQuota
metadata:
  name: {{ project_name }}-quota
  namespace: {{ project_name }}
  annotations:
    nist-csf.control: "PR.AC-1"
    description: "Resource quotas implementing NIST CSF Protect controls"
spec:
  hard:
    requests.cpu: "1"
    requests.memory: 1Gi
    limits.cpu: "2"
    limits.memory: 2Gi
    persistentvolumeclaims: "4"
    pods: "10"
    services: "5"
    secrets: "10"
    configmaps: "10"

# NIST Cybersecurity Framework Implementation for {{ project_name }}
# Generated by DevOps Project Generator

# Security Policy Document
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ project_name }}-security-policy
  namespace: {{ project_name }}
  labels:
    app: {{ project_name }}
    security-framework: nist-csf
data:
  security-policy.md: |
    # Security Policy - {{ project_name }}
    
    ## NIST Cybersecurity Framework Implementation
    
    ### Identify (ID.AM-1, ID.RA-1)
    - Asset management implemented with Kubernetes labels and annotations
    - Risk assessment conducted through automated vulnerability scanning
    - Network policies identify and control data flows
    
    ### Protect (PR.AC-1, PR.DS-1, PR.PT-1)
    - Access control implemented with RBAC and network policies
    - Data protection through encryption at rest and in transit
    - Protective technology through security scanning and runtime protection
    
    ### Detect (DE.CM-1, DE.AE-1)
    - Continuous monitoring through Prometheus metrics and logging
    - Anomalous activity detection through alert rules
    - Security event correlation and analysis
    
    ### Respond (RS.RP-1, RS.AN-1)
    - Response planning through automated incident response playbooks
    - Analysis conducted through security event triage
    - Communication through alerting and notification systems
    
    ### Recover (RC.RP-1, RC.IM-1)
    - Recovery planning through backup and disaster recovery procedures
    - Improvements implemented through post-incident reviews
    
    ## Security Controls Implemented
    
    ### Access Control
    - Kubernetes RBAC with principle of least privilege
    - Network policies restricting pod-to-pod communication
    - Service account management and token rotation
    
    ### Data Protection
    - TLS encryption for all network communications
    - Secrets management with Kubernetes secrets or external vault
    - Encrypted storage for persistent volumes
    
    ### Monitoring and Logging
    - Comprehensive audit logging
    - Real-time security monitoring
    - Automated threat detection
    
    ### Vulnerability Management
    - Container image scanning
    - Dependency vulnerability assessment
    - Regular security updates and patching
---
# Network Policy Implementation
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ project_name }}-nist-network-policy
  namespace: {{ project_name }}
  annotations:
    nist-csf.control: "PR.AC-1"
    description: "Network access control implementing NIST CSF Protect controls"
spec:
  podSelector:
    matchLabels:
      app: {{ project_name }}
  policyTypes:
  - Ingress
  - Egress
  ingress:
  # Allow traffic from ingress controller
  - from:
    - namespaceSelector:
        matchLabels:
          name: ingress-nginx
    ports:
    - protocol: TCP
      port: 8080
  # Allow traffic from monitoring namespace
  - from:
    - namespaceSelector:
        matchLabels:
          name: monitoring
    ports:
    - protocol: TCP
      port: 8080
  # Allow metrics scraping
  - ports:
    - protocol: TCP
      port: 8080
    - protocol: TCP
      port: 9090
  egress:
  # Allow DNS resolution
  - to: []
    ports:
    - protocol: UDP
      port: 53
    - protocol: TCP
      port: 53
  # Allow HTTPS for external APIs
  - to: []
    ports:
    - protocol: TCP
      port: 443
  # Allow HTTP for package repositories
  - to: []
    ports:
    - protocol: TCP
      port: 80
---
# Pod Security Policy
apiVersion: policy/v1beta1
kind: PodSecurityPolicy
metadata:
  name: {{ project_name }}-nist-psp
  annotations:
    nist-csf.control: "PR.PT-1"
    description: "Pod security implementing NIST CSF Protect controls"
spec:
  privileged: false
  allowPrivilegeEscalation: false
  requiredDropCapabilities:
    - ALL
  volumes:
    - 'configMap'
    - 'emptyDir'
    - 'projected'
    - 'secret'
    - 'downwardAPI'
    - 'persistentVolumeClaim'
  runAsUser:
    rule: 'MustRunAsNonRoot'
  seLinux:
    rule: 'RunAsAny'
  fsGroup:
    rule: 'RunAsAny'
  readOnlyRootFilesystem: true
---
# RBAC Configuration
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  namespace: {{ project_name }}
  name: {{ project_name }}-operator
  annotations:
    nist-csf.control: "PR.AC-1"
    description: "Role-based access control implementing NIST CSF Protect controls"
rules:
- apiGroups: [""]
  resources: ["pods", "services", "configmaps", "secrets"]
  verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
- apiGroups: ["apps"]
  resources: ["deployments", "replicasets"]
  verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
- apiGroups: ["argoproj.io"]
  resources: ["rollouts"]
  verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ project_name }}-operator-binding
  namespace: {{ project_name }}
subjects:
- kind: ServiceAccount
  name: {{ project_name }}-operator
  namespace: {{ project_name }}
roleRef:
  kind: Role
  name: {{ project_name }}-operator
  apiGroup: rbac.authorization.k8s.io
---
# Service Account
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ project_name }}-operator
  namespace: {{ project_name }}
  annotations:
    nist-csf.control: "PR.AC-1"
    description: "Service account with minimal required permissions"

# Security Context Constraints
apiVersion: v1
kind: Pod
metadata:
  name: {{ project_name }}-security-demo
  namespace: {{ project_name }}
  annotations:
    nist-csf.control: "PR.PT-1"
    description: "Pod demonstrating NIST CSF security context"
spec:
  securityContext:
    runAsNonRoot: true
    runAsUser: 1000
    runAsGroup: 3000
    fsGroup: 2000
  containers:
  - name: {{ project_name }}
    image: {{ project_name }}:latest
    securityContext:
      allowPrivilegeEscalation: false
      readOnlyRootFilesystem: true
      capabilities:
        drop:
        - ALL
      privileged: false
    resources:
      requests:
        memory: "128Mi"
        cpu: "100m"
      limits:
        memory: "512Mi"
        cpu: "500m"
    volumeMounts:
    - name: tmp
      mountPath: /tmp
    - name: config
      mountPath: /app/config
      readOnly: true
  volumes:
  - name: tmp
    emptyDir: {}
  - name: config
    configMap:
      name: {{ project_name }}-config
